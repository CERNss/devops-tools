LISTEN_ADDR=:9090
AGENT_SECRET=change-me
# Optional basic API key auth. Leave empty to require webhook HMAC auth.
API_KEY=

APP_ROOT=/opt/apps

NPM_BASE_URL=http://127.0.0.1:81
NPM_EMAIL=admin@example.com
NPM_PASSWORD=password

# host-port: NPM forwards to PROXY_FORWARD_HOST:host_port.
# container: NPM forwards to app_name:container_port on a shared Docker network.
PROXY_FORWARD_MODE=host-port
PROXY_FORWARD_HOST=127.0.0.1

# All app directories and rendered files must stay under APP_ROOT.
